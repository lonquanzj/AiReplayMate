#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
APP_HOME="$SCRIPT_DIR"
GRADLE_VERSION="${GRADLE_VERSION:-8.9}"
DEFAULT_GRADLE_HOME="$APP_HOME/.gradle-dist/gradle-$GRADLE_VERSION"
GRADLE_HOME="${GRADLE_HOME:-$DEFAULT_GRADLE_HOME}"

ensure_gradle_home() {
  local expected_launcher="$GRADLE_HOME/lib/gradle-launcher-$GRADLE_VERSION.jar"
  if [[ -f "$expected_launcher" ]]; then
    return 0
  fi

  if [[ "$GRADLE_HOME" != "$DEFAULT_GRADLE_HOME" ]]; then
    echo "Gradle launcher not found at $expected_launcher" >&2
    echo "Set GRADLE_HOME to a Gradle $GRADLE_VERSION installation or unset it to auto-download." >&2
    exit 1
  fi

  if ! command -v curl >/dev/null 2>&1; then
    echo "curl is required to download Gradle $GRADLE_VERSION automatically." >&2
    exit 1
  fi

  if ! command -v unzip >/dev/null 2>&1; then
    echo "unzip is required to extract Gradle $GRADLE_VERSION automatically." >&2
    exit 1
  fi

  local dist_dir="$APP_HOME/.gradle-dist"
  local zip_path="$dist_dir/gradle-$GRADLE_VERSION-bin.zip"
  local download_url="https://services.gradle.org/distributions/gradle-$GRADLE_VERSION-bin.zip"

  mkdir -p "$dist_dir"

  if [[ ! -f "$zip_path" ]]; then
    echo "Downloading Gradle $GRADLE_VERSION..." >&2
    curl -L --fail --retry 3 --output "$zip_path" "$download_url"
  fi

  if [[ ! -d "$GRADLE_HOME" ]]; then
    echo "Extracting Gradle $GRADLE_VERSION..." >&2
    unzip -q -o "$zip_path" -d "$dist_dir"
  fi

  if [[ ! -f "$expected_launcher" ]]; then
    echo "Gradle launcher not found after extraction: $expected_launcher" >&2
    exit 1
  fi
}

ensure_gradle_home

LAUNCHER_JAR="$(find "$GRADLE_HOME/lib" -maxdepth 1 -name 'gradle-launcher-*.jar' | head -n 1)"
AGENT_JAR="$(find "$GRADLE_HOME/lib/agents" -maxdepth 1 -name 'gradle-instrumentation-agent-*.jar' | head -n 1)"

if [[ -z "$LAUNCHER_JAR" ]]; then
  echo "Unable to locate Gradle launcher under $GRADLE_HOME/lib" >&2
  exit 1
fi

if [[ -n "${JAVA_HOME:-}" ]]; then
  JAVA_BIN="$JAVA_HOME/bin/java"
else
  JAVA_BIN="java"
fi

if ! command -v "$JAVA_BIN" >/dev/null 2>&1; then
  echo "Java runtime not found. Set JAVA_HOME or ensure 'java' is on PATH." >&2
  exit 1
fi

# Keep Gradle state in a project-local writable directory instead of ~/.gradle,
# and disable the native integration that fails in this environment.
: "${GRADLE_USER_HOME:=$APP_HOME/.gradle-user-home}"
mkdir -p "$GRADLE_USER_HOME"
export GRADLE_USER_HOME

JAVA_ARGS=(
  --add-opens=java.base/java.util=ALL-UNNAMED
  --add-opens=java.base/java.lang=ALL-UNNAMED
  --add-opens=java.base/java.lang.invoke=ALL-UNNAMED
  --add-opens=java.prefs/java.util.prefs=ALL-UNNAMED
  --add-opens=java.base/java.nio.charset=ALL-UNNAMED
  --add-opens=java.base/java.net=ALL-UNNAMED
  --add-opens=java.base/java.util.concurrent.atomic=ALL-UNNAMED
  -Dorg.gradle.native=false
  -Dorg.gradle.daemon=false
  -Dorg.gradle.jvmargs=
  -Dfile.encoding=UTF-8
  -cp
  "$LAUNCHER_JAR"
)

if [[ -n "$AGENT_JAR" ]]; then
  JAVA_ARGS+=(-javaagent:"$AGENT_JAR")
fi

exec "$JAVA_BIN" \
  "${JAVA_ARGS[@]}" \
  org.gradle.launcher.GradleMain \
  -p "$APP_HOME" \
  --no-daemon \
  "$@"
